<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Talks to the real backend over HTTPS — INTERNET is the only
         permission needed for that. CAMERA is requested at runtime (not
         declared as a hard requirement) since receipt capture also
         supports picking an existing photo, so the app should still be
         usable on a device with no camera or with the permission denied. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".LogandApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.Logand"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Logand">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receipt photo capture writes to this app's own cache dir and
             hands a content:// Uri to the system camera app via
             FileProvider — required on modern Android (a plain file://
             Uri crossing the process boundary to the camera app throws
             FileUriExposedException on API 24+). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="app.logand.mobile.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
