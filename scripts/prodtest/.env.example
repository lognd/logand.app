# Copy to scripts/prodtest/.env and fill in real values. This is a
# separate credential from backend/.env's SEED_ADMIN_* -- a real,
# already-seeded admin account on production that this harness is
# allowed to log in as and use the full admin surface with.
#
# This file (the real .env, not this .example) must never be committed
# -- see the repo's root .gitignore.

PRODTEST_BASE_URL=https://logand.app
PRODTEST_SSH_HOST=hetzner
# The actual login password for the PRODTEST_ADMIN_EMAIL account on
# production -- i.e. whatever password you'd type into
# https://logand.app/login for that account. Not an API key, not a
# provider-issued secret -- just this app's own admin login password,
# the same one you'd hand-type into the login form.
#
# If you currently have no admin account other than the SEED_ADMIN_*
# bootstrap pair (see backend/.env.example), that IS a real, working
# admin login and can be used here for now -- but see docs/deployment.md
# step 4 and this file's own header comment above: SEED_ADMIN_* is meant
# to be removed from backend/.env right after bootstrap, and every
# backend restart while it's still set re-applies that password. Once
# you've created a dedicated admin account through the app itself,
# switch PRODTEST_ADMIN_EMAIL/PASSWORD to that one instead.
PRODTEST_ADMIN_EMAIL=you@example.com
PRODTEST_ADMIN_PASSWORD=changeme

# Only needed if the VPS's container/DB names ever diverge from these
# defaults (docker-compose.yml's service names + postgres.env's
# POSTGRES_USER/POSTGRES_DB).
PRODTEST_BACKEND_CONTAINER=logandapp-backend-1
PRODTEST_POSTGRES_CONTAINER=logandapp-postgres-1
PRODTEST_DB_USER=logand
PRODTEST_DB_NAME=logand
PRODTEST_STORAGE_LOCAL_DIR=/app/data/storage

# Real address the notification-flow probe (probes/notification_flow.py)
# registers its throwaway customer under and sends a real invoice/payment
# notification to, over the real configured SMTP credentials. Defaults to
# a "prodtest" prefix under logand.app, which the domain's own catch-all
# routes to logan@logand.app's inbox -- override this if that routing
# ever changes, or if you'd rather point this at a dedicated mailbox
# instead of piggybacking on the catch-all.
PRODTEST_NOTIFICATION_EMAIL=prodtest@logand.app
