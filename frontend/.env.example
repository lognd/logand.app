# Copy to .env.local for local overrides (gitignored). Never commit real secrets here --
# this file is for Vite's import.meta.env, not server-side secrets.

# Set to "true" to run the frontend standalone against a fake/mocked API
# (Mock Service Worker, see src/mocks/) instead of the real backend -- lets
# you preview the entire site without running backend/. Use `npm run
# dev:mock` instead of setting this by hand; that script sets it for you.
VITE_USE_MOCKS=false
