# Copy to .env and fill in real values. Never commit .env.
# Agents: never read this file's real counterpart (.env), directly or indirectly.

DATABASE_URL=postgresql+asyncpg://logand:changeme@localhost:5432/logand
# MUST match the password embedded in DATABASE_URL above exactly --
# docker-compose.yml's postgres service reads this to set up the
# database's actual superuser password on first init; the backend
# container only ever uses DATABASE_URL to connect. Two different
# passwords here means the backend can't authenticate at all (and the
# postgres container refuses to start with no POSTGRES_PASSWORD set at
# all). Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=changeme
REDIS_URL=redis://localhost:6379/0

# HMAC key for signing CSRF tokens (NOT session IDs -- those are random).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=changeme-generate-a-real-32-byte-token

# Stripe secret key (sk_test_... in dev, sk_live_... in prod).
PAYMENT_PROCESSOR_SECRET=sk_test_fake

# Stripe webhook signing secret (whsec_...), from the Stripe CLI or dashboard.
STRIPE_WEBHOOK_SECRET=whsec_fake

# Stripe PUBLISHABLE key (pk_test_... in dev, pk_live_... in prod) -- the
# customer pay page needs it in the browser to mount Stripe's card form,
# and HIDES the "Pay with card" option entirely while this is unset. Must
# be from the same Stripe account+mode as PAYMENT_PROCESSOR_SECRET above.
STRIPE_PUBLISHABLE_KEY=pk_test_XXXX

# Only set in test/CI, pointing at testing/fake_stripe.py's local double --
# leave unset in production (defaults to the real api.stripe.com).
# STRIPE_API_BASE=http://localhost:12111

# PayPal is fully optional -- leave both unset and the app runs fine,
# gracefully offering only Stripe + manually-recorded payments (Zelle,
# in-person, PayPal sent directly and recorded by hand). Set both together
# from your PayPal developer dashboard's REST API app credentials to turn
# on the real "Pay with PayPal" button.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
# Only set in test/CI, pointing at testing/fake_paypal.py's local double.
# PAYPAL_API_BASE=http://localhost:12112

# Used to build absolute links in generated invoice PDFs (e.g. "Pay online")
# and PayPal's redirect-back URL -- must be the real public URL this app is
# served at.
PUBLIC_BASE_URL=https://example.com

# Invoice PDF letterhead -- shown on every generated invoice.
INVOICE_BUSINESS_NAME=Example Business, LLC.
# Freeform, printed directly under INVOICE_BUSINESS_NAME -- normally just
# your mailing address. Do not put an EIN or other tax ID here.
INVOICE_BUSINESS_DETAILS=
INVOICE_CONTACT_EMAIL=billing@example.com

# Optional -- a customer's Pay page only shows a "Zelle: <this>" option
# once it's set. A phone number or email, whatever your Zelle account is
# registered under.
ZELLE_HANDLE=
# Optional -- shows a "PayPal: <this>" line on the Pay page for customers
# who want to send a manual payment directly. The confirmed email on your
# PayPal account. Separate from PAYPAL_CLIENT_ID/SECRET above (the button);
# this is only the direct-send address.
PAYPAL_RECEIVE_EMAIL=

# Opt-in only -- creates (or updates the password of) an admin account on
# every app startup if BOTH are set. Leave unset after your first deploy;
# a real production deployment shouldn't carry a well-known admin
# credential in an env var indefinitely. See docs/deployment.md.
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=

# Email notifications (invoice sent / payment received) are fully optional --
# leave SMTP_HOST (and GMAIL_* below) unset and every notification is a
# silent no-op, nothing else depends on it. See secrets.md's SMTP/Gmail
# OAuth2 sections for full setup instructions.
#
# DO NOT use smtp.gmail.com + a Google/Workspace App Password -- Google
# fully retired password-based SMTP auth for Google Workspace accounts in
# March 2025 (a custom domain like yourdomain.com is Workspace, not
# personal Gmail); it will fail with 535 "Username and Password not
# accepted" no matter how correct the password is, because that whole
# auth mechanism is gone, not misconfigured. If your sending address is a
# Workspace account, use the GMAIL_* block below instead. If it's a
# personal (non-Workspace) @gmail.com address, or any OTHER SMTP provider
# (Postmark, SES, Fastmail, self-hosted), SMTP_HOST/SMTP_PASSWORD below
# still works normally -- this only affects Workspace.
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USERNAME=billing@yourdomain.com
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_FROM_ADDRESS=billing@yourdomain.com

# Gmail via OAuth2 -- the ONLY way left to send mail through a Google
# Workspace mailbox (see the note above SMTP_HOST). Requires a Google
# Cloud service account with domain-wide delegation authorized in the
# Workspace Admin console; see secrets.md's Gmail OAuth2 section for the
# full walkthrough. Set BOTH together; leave both unset if you're using
# SMTP_HOST above instead (mutually exclusive in practice -- Gmail OAuth2
# takes precedence if somehow both are set).
# GMAIL_SERVICE_ACCOUNT_JSON is the ENTIRE downloaded service-account key
# file's JSON content, as one single-line value (a real private key,
# never commit it, same as everything else in this file's real .env).
# GMAIL_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
# GMAIL_SENDER_EMAIL=billing@yourdomain.com

# Required if SMTP_HOST or GMAIL_SENDER_EMAIL is set -- CAN-SPAM requires
# a real physical postal address in every commercial email's footer.
# Leave unset if email notifications are fully disabled.
# MAILING_ADDRESS=123 Main St, Springfield, ST 00000

# File storage backend for budget evidence, receipts, and documents/CAD
# files -- "local" (default, zero-config) or "r2". See
# docs/design/13-storage-abstraction.md for the full local-vs-R2-vs-NAS
# reasoning. docker-compose.yml mounts a real named volume at
# STORAGE_LOCAL_DIR so "local" survives container restarts/redeploys --
# don't point this at an unmounted path in production.
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/app/data/storage

# Only needed if STORAGE_BACKEND=r2 -- create a bucket + scoped API token
# in the Cloudflare dashboard (R2 > Manage API Tokens). R2_PUBLIC_BASE_URL
# is optional (only if you've opted the bucket into public read access via
# a custom domain); leaving it unset means files are always proxied
# through this backend's own authenticated routes, the safer default.
# R2_BUCKET=
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_BASE_URL=

# Also reused by ops/backup.sh as the off-box backup destination
# regardless of STORAGE_BACKEND above (see docs/design/11-deployment.md) --
# set these even if you're running STORAGE_BACKEND=local, so nightly
# backups still have somewhere real to go. A separate bucket (or at least
# a separate prefix) from any storage-backend R2 bucket is recommended so
# a bug in one doesn't corrupt the other.
# BACKUP_R2_BUCKET=
# BACKUP_R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# BACKUP_R2_ACCESS_KEY_ID=
# BACKUP_R2_SECRET_ACCESS_KEY=

# Where the backend/scheduler write rotating JSON log files (see
# logging/logger.py, logging/handler.py, logging/retention.py). Default
# is ./logs, relative to the image's WORKDIR /app -- docker-compose.yml
# mounts a real named volume there (app_logs) so logs survive container
# restarts/redeploys and are retrievable via /api/admin/logs, same
# survives-a-redeploy convention as STORAGE_LOCAL_DIR above.
LOG_DIR=/app/logs
