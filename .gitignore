# Build artifacts
build/
dist/
*.egg-info/
target/
pkg/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Node
node_modules/
frontend/dist/
frontend/test-results/
frontend/playwright-report/
frontend/coverage/

# Local-only dev preview copies of project-showcase media -- the real
# public copies live in R2 (see backend/src/logand_backend/scripts/
# upload_public_asset.py), never committed to git. This lets
# VITE_MEDIA_BASE_URL point at a local dev-server path to preview
# Projects.tsx with real images before anything is actually uploaded.
frontend/public/local-media/

# Rust
wasm-ascii/target/
wasm-ascii/pkg/

# Android -- local.properties has a machine-specific sdk.dir path,
# never committed. build/ is already covered by the generic rule above.
android/local.properties
android/.gradle/
android/*/build/
android/.cxx/
*.apk
*.aab

# frob local state
.frob/
FROBLEMS.md

# AI assistant working artifacts -- scratch audit findings (regenerated per
# pass) and assistant instruction files, never tracked deliverables.
FINDINGS.md
FINDINGS-*.md
CLAUDE.md
.claude/

# Local storage backend (STORAGE_BACKEND=local, the default) -- real
# uploaded evidence/receipts/documents, never committed.
backend/data/

# Rotating log files (LOG_DIR, default ./logs relative to wherever the
# backend/scheduler process runs -- see logging/logger.py). Real runtime
# output, never committed, same as backend/data/ above.
#
# Both patterns are ANCHORED with a leading slash. An unanchored `logs/`
# matches a directory named "logs" at ANY depth, which silently swallowed
# the Android admin-logs UI package
# (android/app/src/main/kotlin/app/logand/mobile/ui/admin/logs/) -- it
# built fine locally, where the files exist on disk, and broke CI with
# "Unresolved reference: AdminLogsViewModel" on a fresh clone.
/backend/logs/
/logs/

# Secrets
.env
.env.local
backend/.env

# Editor / OS
.idea/
.DS_Store
